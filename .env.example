# ZAPLE Backend Environment Variables
# ─────────────────────────────────────
# Copy this file to .env.local for local development
# Add these as Environment Variables in Vercel dashboard

# Your Claude API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: restrict which domains can call your API
# Leave blank to allow all (fine for now)
ALLOWED_ORIGINS=https://zaple.io,chrome-extension://your-extension-id
